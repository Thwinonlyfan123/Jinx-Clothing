<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Email Verification - Jinx Clothing</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
        }
        body {
            background: #ffffff;
            color: #222222;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .verification-container {
            width: 100%;
            max-width: 440px;
            background: #ffffff;
            border: 1px solid #e5e5e5;
            padding: 40px;
            text-align: center;
        }
        h3 {
            font-size: 22px;
            font-weight: 300;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #111111;
            margin-bottom: 16px;
        }
        p {
            font-size: 14px;
            color: #666666;
            line-height: 1.6;
            margin-bottom: 24px;
        }
        p strong {
            color: #111111;
            font-weight: 500;
        }
        .alert-error {
            background: #fdf2f2;
            border: 1px solid #f87171;
            color: #cc3333;
            padding: 12px;
            font-size: 13px;
            margin-bottom: 24px;
            text-align: left;
        }
        label {
            display: block;
            text-align: left;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #444444;
            margin-bottom: 10px;
        }
        input {
            width: 100%;
            padding: 14px;
            background: #fafafa;
            border: 1px solid #e5e5e5;
            color: #111111;
            font-size: 20px;
            font-weight: 600;
            text-align: center;
            letter-spacing: 6px;
            margin-bottom: 24px;
            transition: all 0.2s ease;
        }
        input:focus {
            border-color: #999999;
            background: #ffffff;
            outline: none;
        }
        input::placeholder {
            color: #cccccc;
            letter-spacing: 4px;
        }
        .btn {
            width: 100%;
            background: #111111;
            color: #ffffff;
            padding: 14px;
            border: none;
            font-size: 13px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            transition: background 0.2s ease;
        }
        .btn:hover {
            background: #444444;
        }
        .footer-links {
            margin-top: 24px;
            font-size: 13px;
            color: #777777;
        }
        .footer-links a {
            color: #111111;
            text-decoration: none;
            font-weight: 500;
            margin-left: 4px;
            border-bottom: 1px solid transparent;
            transition: border-color 0.2s ease;
        }
        .footer-links a:hover {
            border-color: #111111;
        }
    </style>
</head>
<body>

    <div class="verification-container">
        
        <h3>Verify Account</h3>
        <p>
            A 6-digit OTP security code has been sent to your registered email address at <strong><%= email %></strong>.
        </p>

        <% if (error) { %>
            <div class="alert-error" role="alert">
                ⚠️ <%= error %>
            </div>
        <% } %>

        <form action="/verify-otp" method="POST">
            <div>
                <label for="otp">Enter OTP Code</label>
                <input 
                    type="text" 
                    name="userEnteredCode" 
                    id="otp" 
                    placeholder="••••••" 
                    maxlength="6" 
                    required 
                    autocomplete="off"
                >
            </div>

            <button type="submit" class="btn">
                Confirm Code
            </button>
        </form>

        <div class="footer-links">
            <span>Didn't receive the code?</span> 
            <a href="/register">Try again</a>
        </div>

    </div>

    <script>
        document.getElementById('otp').addEventListener('input', function (e) {
            this.value = this.value.replace(/[^0-9]/g, '');
        });
    </script>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Products - Jinx Clothing</title>
<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
}
body{
    background:#ffffff;
    min-height:100vh;
    color:#222222;
}
header{
    text-align:center;
    padding:60px 40px 40px 40px;
}
header h1{
    color:#111111;
    font-size:28px;
    font-weight:300;
    letter-spacing:3px;
    text-transform:uppercase;
}
.nav-links {
    margin-top: 20px;
    display: flex;
    justify-content: center;
    gap: 15px;
}
.products{
    width:90%;
    max-width:1300px;
    margin:auto;
    padding-bottom:80px;
    display:grid;
    grid-template-columns: repeat(auto-fit,minmax(280px,1fr));
    gap:40px;
}
.card{
    background:#ffffff;
    overflow:hidden;
    transition:.3s ease;
    position:relative;
}
.card:hover{
    transform: translateY(-5px);
}
.card img{
    width:100%;
    height:360px;
    object-fit:cover;
    transition:.4s ease;
    background:#fafafa;
}
.card:hover img{
    transform:scale(1.02);
}
.content{
    padding:16px 0;
    color:#222222;
}
.content h3{
    margin-bottom:6px;
    font-size:16px;
    font-weight:400;
    text-transform:uppercase;
    letter-spacing:0.5px;
    color:#111111;
}
.rating{
    color:#dddddd;
    font-size:12px;
    margin-bottom:8px;
    letter-spacing:1px;
}
/* Replaces gold stars with cleaner styling if needed, keeping text element intact */
.price{
    margin-bottom:12px;
    font-size:15px;
}
.new-price{
    color:#111111;
    font-weight:500;
}
.old-price{
    margin-left:8px;
    text-decoration:line-through;
    color:#999999;
    font-size:13px;
}
.desc{
    color:#666666;
    line-height:1.6;
    font-size:13px;
    margin-bottom:16px;
}
.btn{
    width:100%;
    padding:12px;
    border:1px solid #e5e5e5;
    border-radius:0px;
    background: transparent;
    color:#111111;
    font-size:12px;
    text-transform:uppercase;
    letter-spacing:1px;
    font-weight:500;
    cursor:pointer;
    transition:.2s ease;
}
.btn:hover{
    border-color:#111111;
    background: #111111;
    color:white;
}
.badge{
    position:absolute;
    top:15px;
    left:15px;
    background:#111111;
    color:white;
    padding:5px 12px;
    font-size:11px;
    letter-spacing:1px;
    font-weight:500;
    z-index: 10;
}
.cart-link, .admin-link {
    display:inline-block;
    color:#555555;
    background:transparent;
    border:1px solid #e5e5e5;
    padding:10px 20px;
    border-radius:0px;
    text-decoration:none;
    font-size:12px;
    text-transform:uppercase;
    letter-spacing:1px;
    font-weight:500;
    transition:.2s ease;
}
.cart-link:hover {
    border-color:#111111;
    color:#111111;
}
.admin-link {
    background: transparent;
    color:#888888;
}
.admin-link:hover {
    border-color:#999999;
    color:#444444;
}
.empty-state {
    color:#777777;
    text-align:center;
    width:100%;
    grid-column:1/-1;
    font-size:15px;
    padding:40px 0;
}
</style>
</head>
<body>

<header>
    <h1>Jinx Clothing</h1>
    <div class="nav-links">
        <a href="/cart" class="cart-link">🛒 View Cart</a>
        <a href="/admin" class="admin-link">🛠️ Admin Panel</a>
    </div>
</header>

<div class="products">
    <% if (!products || products.length === 0) { %>
        <div class="empty-state">No products available right now.</div>
    <% } else { %>
        <% products.forEach(product => { %>
            <div class="card">
                <% if (product.sale || product.is_sale) { %>
                    <span class="badge">SALE</span>
                <% } %>

                <img src="/<%= product.image %>" alt="<%= product.name %>">

                <div class="content">
                    <h3><%= product.name %></h3>
                    <div class="rating">⭐⭐⭐⭐⭐</div>

                    <div class="price">
                        <span class="new-price">$<%= product.price %></span>
                        <% if (product.old_price || product.oldPrice) { %>
                            <span class="old-price">$<%= product.old_price || product.oldPrice %></span>
                        <% } %>
                    </div>

                    <p class="desc"><%= product.description || product.desc || 'High quality fashion item.' %></p>

                    <form action="/add-cart" method="POST">
                        <input type="hidden" name="product_id" value="<%= product.id %>">
                        <button type="submit" class="btn">🛒 Add To Cart</button>
                    </form>
                </div>
            </div>
        <% }) %>
    <% } %>
</div>

</body>
</html>
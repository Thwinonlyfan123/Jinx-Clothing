<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Register - Jinx Clothing</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
}

body{
    height:100vh;
    display:flex;
    background:#ffffff;
}

/* LEFT IMAGE - Nature/Minimalist Aesthetic */
.left{
    flex:1.2;
    background:url('https://images.unsplash.com/photo-1545241047-6083a3684587?q=80&w=1000') center/cover;
    filter: brightness(98%) contrast(95%);
}

/* RIGHT FORM */
.right{
    flex:1;
    display:flex;
    justify-content:center;
    align-items:center;
    background:#ffffff;
    padding:40px;
}

.box{
    width:350px;
}

h2{
    font-size:24px;
    font-weight:400;
    letter-spacing:0.5px;
    margin-bottom:6px;
    color:#111111;
}

p{
    font-size:14px;
    color:#777777;
    margin-bottom:28px;
}

input{
    width:100%;
    padding:14px;
    margin-bottom:14px;
    border:1px solid #e5e5e5;
    border-radius:4px;
    background:#fafafa;
    font-size:14px;
    color:#333333;
    transition: all 0.2s ease;
}

input:focus{
    border-color:#888888;
    background:#ffffff;
    outline:none;
}

button{
    width:100%;
    padding:14px;
    background:#111111;
    color:#fff;
    border:none;
    border-radius:4px;
    font-size:14px;
    font-weight:500;
    letter-spacing:1px;
    text-transform:uppercase;
    cursor:pointer;
    transition:background 0.2s ease;
    margin-top:4px;
}

button:hover{
    background:#444444;
}

a{
    display:block;
    text-align:center;
    margin-top:20px;
    color:#666666;
    font-size:13px;
    text-decoration:none;
    transition:color 0.2s ease;
}

a:hover{
    color:#111111;
    text-decoration:underline;
}

/* 📱 MOBILE */
@media (max-width: 768px){
    body{
        flex-direction:column;
    }

    .left{
        display:none;
    }

    .box{
        width:100%;
    }
}

/* 📟 TABLET */
@media (min-width: 769px) and (max-width: 1024px){
    .box{
        width:300px;
    }
}
</style>
</head>

<body>

<div class="left"></div>

<div class="right">
    <div class="box">
        <h2>Create Account</h2>
        <p>Join Jinx Clothing community</p>

        <form action="/register" method="POST">
            <input type="text" name="name" placeholder="Full Name">
            <input type="email" name="email" placeholder="Email">
            <input type="password" name="password" placeholder="Password">
            <input type="password" name="confirmPassword" placeholder="Confirm Password">
            <button type="submit">Register</button>
        </form>

        <a href="/login">Already have account? Login</a>
    </div>
</div>

</body>
</html>